# Super-PPT 环境变量配置
# 复制此文件为 .env 并填入 API Key

# 默认 LLM Provider（可选: kimi, gemini, grok, deepseek, openai, claude, ...）
LLM_PROVIDER=kimi

# Kimi（月之暗面）
KIMI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# xAI Grok
GROK_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# 通义千问
QWEN_API_KEY=

# 智谱 GLM
GLM_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# PPT 语言（zh/en）
PPT_LANGUAGE=zh

# Cloubic 统一路由配置
# Cloubic (https://cloubic.com) 是 AI 多模型统一调度平台
# 一个 API Key 即可访问 100+ 大模型（OpenAI、Claude、Gemini、DeepSeek 等）

# 是否启用 Cloubic 路由（true/false）
# 启用后所有 LLM 请求通过 Cloubic 转发，无需配置各家 API Key
CLOUBIC_ENABLED=false

# Cloubic API Key（在 https://app.cloubic.com 获取）
CLOUBIC_API_KEY=sk-m92gPJJAjofAm0_Se3uZo2Zl6hlqd93DLUjmAtfrJE0

# Cloubic API 端点
CLOUBIC_BASE_URL=https://api.cloubic.com/v1

# ============ Cloubic 模型映射（2026-03-19 API 实测） ============
# 每个 provider 配置两个模型：默认（长上下文非推理）和推理版
# 通过 GET /v1/models 接口实测确认，共 80 个可用模型

# --- OpenAI ---
# 非推理: gpt-5.4, gpt-5.2-pro, gpt-5.2, gpt-5.1, gpt-5-pro, gpt-5, gpt-5-chat-latest, gpt-4.1-2025-04-14, gpt-4o
# 轻量:   gpt-5-mini, gpt-5-nano, gpt-4.1-mini, gpt-4.1-nano, gpt-4o-mini
# 推理:   o4-mini-2025-04-16
# 图片:   gpt-image-1, dall-e-3
CLOUBIC_OPENAI_MODEL=gpt-5.4
CLOUBIC_OPENAI_REASONING_MODEL=gpt-5.2-pro

# --- Anthropic Claude ---
# 非推理: claude-opus-4-6, claude-opus-4-5-20251101, claude-opus-4-1-20250805, claude-opus-4-20250514, claude-sonnet-4-5-20250929, claude-sonnet-4-20250514
# 轻量:   claude-haiku-4-5-20251001, claude-3-5-haiku-20241022, claude-3-haiku-20240307
# 推理:   claude-sonnet-4-5-20250929-thinking, claude-opus-4-1-20250805-thinking, claude-sonnet-4-20250514-thinking, claude-3-7-sonnet-20250219-thinking, claude-haiku-4-5-20251001-thinking
CLOUBIC_CLAUDE_MODEL=claude-opus-4-6
CLOUBIC_CLAUDE_REASONING_MODEL=claude-sonnet-4-5-20250929-thinking

# --- Google Gemini ---
# 非推理: gemini-3.1-pro-preview, gemini-3-pro-preview, gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash
# 轻量:   gemini-2.5-flash-lite, gemini-2.5-flash
# 图片:   gemini-2.5-flash-image, gemini-3-pro-image-preview
# 推理:   (无专用推理版，gemini-2.5-pro 自带思考能力)
CLOUBIC_GEMINI_MODEL=gemini-3-flash-preview
CLOUBIC_GEMINI_REASONING_MODEL=gemini-3.1-pro-preview

# --- DeepSeek ---
# 非推理: deepseek-v3.2, deepSeek-V3.1
# 推理:   deepSeek-R1-0528
CLOUBIC_DEEPSEEK_MODEL=deepseek-v3.2
CLOUBIC_DEEPSEEK_REASONING_MODEL=deepSeek-R1-0528

# --- xAI Grok ---
# 非推理: grok-4-1-fast-non-reasoning
# 推理:   grok-4-1-fast-reasoning
CLOUBIC_GROK_MODEL=grok-4-1-fast-non-reasoning
CLOUBIC_GROK_REASONING_MODEL=grok-4-1-fast-reasoning

# --- Qwen 通义千问 ---
# 非推理: qwen3-max, qwen3-max-2026-01-23, qwen-plus
# 推理:   (无专用推理版)
CLOUBIC_QWEN_MODEL=qwen3-vl-plus
CLOUBIC_QWEN_REASONING_MODEL=qwen3-max-2026-01-23

# --- 豆包 Doubao ---
# 非推理: doubao-seed-1-6-flash-250828, doubao-1-5-pro-32k-250115
# 推理:   doubao-seed-1-6-251015
CLOUBIC_DOUBAO_MODEL=doubao-seed-1-6-flash-250828
CLOUBIC_DOUBAO_REASONING_MODEL=doubao-seed-1-6-251015

# --- MiniMax ---
# 非推理: MiniMax-Hailuo-2.3, MiniMax-Hailuo-2.3-Fast, MiniMax-Hailuo-02
# 推理:   (无专用推理版)
CLOUBIC_MINIMAX_MODEL=MiniMax-Hailuo-2.3
CLOUBIC_MINIMAX_REASONING_MODEL=MiniMax-Hailuo-2.3

# --- Kimi（Cloubic 无 Kimi 系列，回退到 DeepSeek） ---
CLOUBIC_KIMI_MODEL=deepseek-v3.2

# --- 图片生成模型（ai_images + infographics 共用） ---
# Cloubic 也支持: gpt-image-1, dall-e-3, doubao-seedream-4-5-251128
CLOUBIC_IMAGE_MODEL=gemini-3-pro-image-preview

# ============ 默认 Provider（Cloubic 模式下） ============
# Cloubic 启用时的默认 provider（决定用哪家模型）
# 可选: openai, claude, gemini, deepseek, grok, qwen, doubao, minimax
CLOUBIC_DEFAULT_PROVIDER=deepseek

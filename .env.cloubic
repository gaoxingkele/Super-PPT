# Cloubic 统一路由配置
# Cloubic (https://cloubic.com) 是 AI 多模型统一调度平台
# 一个 API Key 即可访问 100+ 大模型（OpenAI、Claude、Gemini、DeepSeek 等）

# 是否启用 Cloubic 路由（true/false）
# 启用后所有 LLM 请求通过 Cloubic 转发，无需配置各家 API Key
CLOUBIC_ENABLED=false

# Cloubic API Key（在 https://app.cloubic.com 获取）
CLOUBIC_API_KEY=

# Cloubic API 端点
CLOUBIC_BASE_URL=https://api.cloubic.com/v1

# ============ Cloubic 模型映射 ============
# 通过 Cloubic 调用时使用的模型 ID（与原厂一致）
# 留空则使用各 provider 在 .env 中配置的默认模型

# OpenAI 系列（确认支持: gpt-4o, gpt-4o-mini, gpt-4, gpt-5.1, gpt-5-pro）
CLOUBIC_OPENAI_MODEL=gpt-4o
# Anthropic 系列（确认支持: claude-sonnet-4-5-20250929, claude-3-7-sonnet-latest, claude-3-5-sonnet-20241022）
CLOUBIC_CLAUDE_MODEL=claude-sonnet-4-5-20250929
# Google 系列（确认支持: gemini-2.0-flash, gemini-2.0-flash-exp）
CLOUBIC_GEMINI_MODEL=gemini-2.0-flash
# DeepSeek 系列（模型ID与原厂一致）
CLOUBIC_DEEPSEEK_MODEL=deepseek-chat
# xAI 系列（模型ID与原厂一致）
CLOUBIC_GROK_MODEL=grok-3
# Qwen 系列（模型ID与原厂一致）
CLOUBIC_QWEN_MODEL=qwen-plus
# GLM 系列（模型ID与原厂一致）
CLOUBIC_GLM_MODEL=glm-4-plus
# MiniMax 系列（模型ID与原厂一致）
CLOUBIC_MINIMAX_MODEL=MiniMax-Text-01
# Kimi 系列（模型ID与原厂一致）
CLOUBIC_KIMI_MODEL=moonshot-v1-128k

# ============ 默认 Provider（Cloubic 模式下） ============
# Cloubic 启用时的默认 provider（决定用哪家模型）
# 可选: openai, claude, gemini, deepseek, grok, qwen, glm, kimi, minimax
CLOUBIC_DEFAULT_PROVIDER=deepseek
